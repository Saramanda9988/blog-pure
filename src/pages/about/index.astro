---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'gossips', text: 'Gossips' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <img
    src='/images/social-card.png'
    alt='Cover Image'
    class='cover-image relative z-10 h-auto w-full rounded-2xl object-cover mb-8'
    loading='eager'
    fetchpriority='high'
  />
  {/* about-me */}
  <p class='text-muted-foreground'>Button Painter / JSON Worker / Bug Maker</p>
  <p class='text-muted-foreground'>
    你好，我叫 Lunarain_079，还可以叫我 独酌清月/寒蝉 <Spoiler>网名太多了啊嗯🙀</Spoiler>，请随意称呼我
  </p>
  <p class='text-muted-foreground'>
    Java/Go选手，React新人，“中端工程师”
  </p>
  <p class='text-muted-foreground'>
    热爱计算机技术，刷过几门公开课，还喜欢瞎折腾，渴望学习更多有趣的知识
  </p>
  <p class='text-muted-foreground'>
    Galgame & Rhythm game enjoyer, Rock & Vocaloid listener
  </p>
  <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' variant='ahead' />

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>我在使用的一些工具:</p>
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Chrome',
        description: 'Browser',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Firefox',
        description: 'Browser',
        href: 'https://www.mozilla.org/en-US/firefox',
        icon: import('@/assets/tools/firefox.svg?raw')
      },
      {
        name: 'Siyuan Note',
        description: 'Note Taking',
        href: 'https://b3log.org/siyuan/',
        icon: import('@/assets/tools/siyuan.svg?raw')
      },
      {
        name: 'Clash Verge',
        description: 'Proxy Client',
        href: 'https://www.clashverge.dev/',
        icon: import('@/assets/tools/clash.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      {
        name: 'VS Code',
        description: 'IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Cursor',
        description: 'IDE',
        href: 'https://cursor.so/',
        icon: import('@/assets/tools/cursor.svg?raw')
      },
      {
        name: 'JetBrains IntelliJ IDEA',
        description: 'IDE',
        href: 'https://www.jetbrains.com/idea/',
        icon: import('@/assets/tools/intellij.svg?raw')
      },
      {
        name: 'JetBrains Goland',
        description: 'IDE',
        href: 'https://www.jetbrains.com/go/',
        icon: import('@/assets/tools/goland.svg?raw')
      },
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Environment'
    tools={[
      {
        name: 'Arch Linux WSL',
        description: 'Linux Distribution for WSL',
        href: 'https://archlinux.org/',
        icon: import('@/assets/tools/archlinux.svg?raw')
      },
      {
        name: 'Ubuntu 24.04 LTS',
        description: 'Linux Distribution for WSL',
        href: 'https://ubuntu.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      },
      {
        name: 'Windows 11',
        description: 'Mechrevo Yaoshi 15 Pro',
        href: 'https://news.microsoft.com/windows11-general-availability/',
        icon: import('@/assets/tools/windows11.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <p>
    你可以在这些地方找到我:
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/Saramanda9988',
        text: 'followers',
        api: 'github/Saramanda9988'
      },
      {
        platform: 'Steam',
        icon: 'steam',
        color: '#50769d',
        link: 'https://steamcommunity.com/id/fufeng_',
        text: 'games',
        api: 'steamgames/76561198908864599'
      },
      {
        platform: 'Bilibili',
        icon: 'bilibili',
        color: '#F77099',
        link: 'https://space.bilibili.com/399704845',
        text: 'followers',
        api: 'bilibili/399704845'
      },
      {
        platform: 'zhihu',
        icon: 'zhihu',
        color: '#2ca5e0',
        link: 'https://www.zhihu.com/people/lunarain079',
        text: 'subscribers',
        api: 'zhihu/lunarain079'
      }
    ]}
  />

  <!-- {/* gossips */}
  <h2 id='gossips'>Gossips</h2>
  <Collapse title='Lorem ipsum'>
    Lorem ipsum dolor sit amet, vidit suscipit at mei. Quem denique mea id. Usu ei regione indoctum
    dissentiunt, cu meliore fuisset mei, vel quod voluptua ne. Ex dicat impedit mel, at eum oratio
    possit voluptatum.
  </Collapse> -->

  {/* about-blog */}
  <h2 id='about-blog'>About Blog</h2>
  <p>
    此网站基于以下项目构建
  </p>
  <ul>
    <li>
      博客框架 & 主题: <a href='https://astro.build/' target='_blank'>Astro</a> + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'>Astro Theme Pure</a
      >
    </li>
    <li>
      静态托管: <a href='https://cloudflare.com/' target='_blank'>Cloudflare</a>
    </li>
    <li>
      CI/CD: <a href='https://cloudflare.com/workflow' target='_blank'>Cloudflare Workflow</a>
    </li>
    <li>评论系统: <a href='https://waline.js.org' target='_blank'>Waline</a></li>
    <li>
      访问统计: <a href='https://umami.is/' target='_blank'>Umami</a> +
      <a href='https://waline.js.org/' target='_blank'>Waline</a>
    </li>
    <li>
      其他统计: <a href='https://github.com/spencerwooo/substats' target='_blank'
        >Substats</a
      >
    </li>
  </ul>
</PageLayout>
